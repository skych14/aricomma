# ──────────────────────────────────────────────────────────────
# 아리쉼표 백엔드 환경변수 예시
# 실제 .env 파일에 복사 후 값을 수정하세요.
# ──────────────────────────────────────────────────────────────

# ── 데이터베이스 ───────────────────────────────────────────────
# 로컬 개발
DATABASE_URL=sqlite:///./ari_project.db
# Fly.io 볼륨 배포 시 (절대 경로, 슬래시 4개)
# DATABASE_URL=sqlite:////data/ari_project.db
# PostgreSQL 전환 시 (코드 변경 없음)
# DATABASE_URL=postgresql://user:password@host:5432/ari_db

# ── 보안 ───────────────────────────────────────────────────────
# 반드시 긴 랜덤 문자열로 변경 (python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-in-production-use-long-random-string

# ── 파일 업로드 ────────────────────────────────────────────────
# 로컬 개발
UPLOAD_DIR=./uploads
# Fly.io 볼륨 배포 시
# UPLOAD_DIR=/data/uploads

# ── CORS ───────────────────────────────────────────────────────
# 로컬 개발
CORS_ORIGINS=http://localhost:5173
# 배포 시: 쉼표로 구분하여 여러 도메인 허용
# CORS_ORIGINS=https://your-app.pages.dev,http://localhost:5173

# ── 예약 만료 시간 ─────────────────────────────────────────────
# 기본 600초 (10분). 개발/테스트 시 짧게 조정 가능
RESERVATION_EXPIRY_SECONDS=600

# ── 초기 관리자 계정 (seed.py 실행 시 생성) ───────────────────
ADMIN_EMAIL=admin@ari.ac.kr
ADMIN_PASSWORD=admin1234
ADMIN_NAME=관리자
